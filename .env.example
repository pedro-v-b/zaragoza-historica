# ============================================================
# Zaragoza Historica - Variables de entorno
# ============================================================
# Copia este fichero a .env y rellena los valores reales.
# .env NO se sube a git.

# ---------- Base de datos ----------
POSTGRES_USER=zaragoza_user
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=zaragoza_historica

DB_HOST=postgres
DB_PORT=5432
DB_NAME=zaragoza_historica
DB_USER=zaragoza_user
DB_PASSWORD=cambia_esta_password

# ---------- Backend ----------
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOADS_DIR=/app/uploads
DEBUG=false

# ---------- JWT / Admin ----------
# IMPORTANTE: generar una clave aleatoria larga para produccion
# Ejemplo: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=cambia_esta_clave_por_una_aleatoria_larga_de_al_menos_32_caracteres
JWT_EXPIRE_MINUTES=30
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_password_admin
